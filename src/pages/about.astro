---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Link from "../components/Link.astro";
import ContactSection from "../components/ContactSection.astro";
---
<BaseLayout title="About | Personal Site" description="About me">
  <Fragment slot="nav"><Nav /></Fragment>
  
  <!-- About me section -->
  <div class="mt-20 max-w-7xl mx-auto">
    <section class="my-12 grid md:grid-cols-2 gap-8 md:gap-12 items-start">
      <div>
        <h2 class="text-3xl md:text-5xl lg:text-5xl leading-tight text-gray-800">
          Experienced Software Engineer with passion for innovation and startups
        </h2>
        <p class="mt-8 text-gray-700 text-lg">
          I'm David, an experienced software engineer with expertise in creating SaaS products, websites, and mobile applications for businesses.
        </p>
        <p class="mt-4 text-gray-700 text-lg">
          I work closely with my colleagues to deliver exceptional results that exceed expectations. If you're looking for a dedicated software engineer to help bring your ideas to life, don't hesitate to send me an email!
        </p>
        <div class="mt-8">
          <Link href="mailto:david@daviddelatorre.com" variant="inline" class="text-xl">
            Let's Work Together →
          </Link>
        </div>
      </div>
      <div class="relative">
        <img
          src="/img/yop.jpg"
          alt="David working at his laptop"
          class="w-full h-auto object-cover shadow-xl/30 border border-gray-300 rounded-lg"
        />
      </div>
    </section>
  </div>

  <!-- Work Experience section -->
  <div class="mt-20 max-w-7xl mx-auto">
    <div class="border-y-4 py-3 mb-8">
      <h2 class="text-lg text-gray-600 uppercase tracking-wider md:text-2xl font-bold text-gray-800">WORK EXPERIENCE</h2>
    </div>
    <section class="my-12 space-y-8">
      <!-- Zinkee - VP de ingeniería -->
      <div class="border border-gray-300 p-8 md:p-10 rounded-lg shadow-sm hover:shadow-md transition-shadow">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
          <div>
            <h3 class="text-2xl md:text-3xl font-semibold text-gray-800">VP de ingeniería</h3>
            <p class="text-lg text-gray-600 mt-1">Zinkee</p>
          </div>
          <span class="text-gray-600 text-sm md:text-base font-medium">Sept. 2024 - Present</span>
        </div>
        <p class="text-gray-700 text-lg leading-relaxed">
          Leading the engineering team at Zinkee, driving the digitalization of processes for small and medium-sized businesses through no-code solutions, and re-founding the team around the new AI-native product development paradigm. Designing and deploying an Event-Driven Architecture to build scalable solutions.
        </p>
      </div>

      <!-- Zinkee - Ingeniero de software -->
      <div class="border border-gray-300 p-8 md:p-10 rounded-lg shadow-sm hover:shadow-md transition-shadow">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
          <div>
            <h3 class="text-2xl md:text-3xl font-semibold text-gray-800">Ingeniero de Software</h3>
            <p class="text-lg text-gray-600 mt-1">Zinkee · Sevilla, Andalucía, España (Híbrido)</p>
          </div>
          <span class="text-gray-600 text-sm md:text-base font-medium">Jun. 2023 - Oct. 2024</span>
        </div>
        <p class="text-gray-700 text-lg leading-relaxed">
          Dedicated to digitalizing processes for small and medium-sized businesses through no-code solutions. Developed and maintained scalable applications using modern technologies.
        </p>
      </div>

      <!-- Mentor - espacio_RES -->
      <div class="border border-gray-300 p-8 md:p-10 rounded-lg shadow-sm hover:shadow-md transition-shadow">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
          <div>
            <h3 class="text-2xl md:text-3xl font-semibold text-gray-800">Mentor</h3>
            <p class="text-lg text-gray-600 mt-1">espacio_RES · Sevilla, Andalucía, España</p>
          </div>
          <span class="text-gray-600 text-sm md:text-base font-medium">May. 2020 - Present</span>
        </div>
        <p class="text-gray-700 text-lg leading-relaxed">
          Actively collaborating as a mentor at espacio_RES, a Sevillian business incubator that aims to help entrepreneurs achieve their goals. Conducting technical mentorship for projects focused on project management and technology implementation.
        </p>
      </div>

      <!-- Fundador - CIMA HORIZONS -->
      <div class="border border-gray-300 p-8 md:p-10 rounded-lg shadow-sm hover:shadow-md transition-shadow">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
          <div>
            <h3 class="text-2xl md:text-3xl font-semibold text-gray-800">Fundador</h3>
            <p class="text-lg text-gray-600 mt-1">CIMA HORIZONS · Sevilla y alrededores, España</p>
          </div>
          <span class="text-gray-600 text-sm md:text-base font-medium">Sept. 2019 - Dec. 2023</span>
        </div>
        <p class="text-gray-700 text-lg leading-relaxed">
          Since my youth, I always knew I wanted to be an entrepreneur. This ambition led me to found Cima Horizons, a pioneering company dedicated to creating immersive experiences in augmented reality and computational design. Led project management and technical development.
        </p>
      </div>

      <!-- Ingeniero de software - everis -->
      <div class="border border-gray-300 p-8 md:p-10 rounded-lg shadow-sm hover:shadow-md transition-shadow">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
          <div>
            <h3 class="text-2xl md:text-3xl font-semibold text-gray-800">Ingeniero de Software</h3>
            <p class="text-lg text-gray-600 mt-1">everis · Sevilla, Andalucía, España</p>
          </div>
          <span class="text-gray-600 text-sm md:text-base font-medium">Sept. 2017 - Mar. 2018</span>
        </div>
        <p class="text-gray-700 text-lg leading-relaxed">
          This role marked my first foray into the professional world. Spent several months working on software that generated the daily Intellectual Property Official Gazette for the Spanish Patent and Trademark Office.
        </p>
      </div>
    </section>
  </div>

  <ContactSection />

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>
