---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Link from "../components/Link.astro";
import ContactSection from "../components/ContactSection.astro";
---
<BaseLayout title="About | Personal Site" description="About me">
  <Fragment slot="nav"><Nav /></Fragment>
  
  <!-- About me section -->
  <div class="mt-20 max-w-7xl mx-auto">
    <section class="my-12 grid md:grid-cols-2 gap-8 md:gap-12 items-start">
      <div>
        <h2 class="text-3xl md:text-5xl lg:text-5xl leading-tight text-gray-800">
          Experienced Software Engineer with passion for innovation and startups
        </h2>
        <p class="mt-8 text-gray-700 text-lg">
          I'm David, an experienced software engineer with expertise in creating SaaS products, websites, and mobile applications for businesses.
        </p>
        <p class="mt-4 text-gray-700 text-lg">
          I work closely with my colleagues to deliver exceptional results that exceed expectations. If you're looking for a dedicated software engineer to help bring your ideas to life, don't hesitate to send me an email!
        </p>
        <div class="mt-8">
          <Link href="mailto:david@daviddelatorre.com" variant="inline" class="text-xl">
            Let's Work Together →
          </Link>
        </div>
      </div>
      <div class="relative">
        <img
          src="/img/yop.jpg"
          alt="David working at his laptop"
          class="w-full h-auto object-cover shadow-xl/30 border border-gray-300 rounded-lg"
        />
      </div>
    </section>
  </div>

  <!-- Work Experience section -->
  <div class="mt-20 max-w-7xl mx-auto">
    <div class="border-y-4 py-3 mb-8">
      <h2 class="text-lg text-gray-600 uppercase tracking-wider md:text-2xl font-bold text-gray-800">WORK EXPERIENCE</h2>
    </div>
    <section class="my-12 space-y-8">
      <!-- Job 1 -->
      <div class="border border-gray-300 p-8 md:p-10 rounded-lg shadow-sm hover:shadow-md transition-shadow">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
          <div>
            <h3 class="text-2xl md:text-3xl font-semibold text-gray-800">Senior Software Engineer</h3>
            <p class="text-lg text-gray-600 mt-1">Company Name</p>
          </div>
          <span class="text-gray-600 text-sm md:text-base font-medium">2022 - Present</span>
        </div>
        <p class="text-gray-700 text-lg leading-relaxed">
          Description of your role and achievements. Add your responsibilities, key projects, and impact here.
        </p>
      </div>

      <!-- Job 2 -->
      <div class="border border-gray-300 p-8 md:p-10 rounded-lg shadow-sm hover:shadow-md transition-shadow">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
          <div>
            <h3 class="text-2xl md:text-3xl font-semibold text-gray-800">Software Engineer</h3>
            <p class="text-lg text-gray-600 mt-1">Previous Company</p>
          </div>
          <span class="text-gray-600 text-sm md:text-base font-medium">2020 - 2022</span>
        </div>
        <p class="text-gray-700 text-lg leading-relaxed">
          Description of your role and achievements. Add your responsibilities, key projects, and impact here.
        </p>
      </div>

      <!-- Job 3 -->
      <div class="border border-gray-300 p-8 md:p-10 rounded-lg shadow-sm hover:shadow-md transition-shadow">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
          <div>
            <h3 class="text-2xl md:text-3xl font-semibold text-gray-800">Junior Software Engineer</h3>
            <p class="text-lg text-gray-600 mt-1">Another Company</p>
          </div>
          <span class="text-gray-600 text-sm md:text-base font-medium">2018 - 2020</span>
        </div>
        <p class="text-gray-700 text-lg leading-relaxed">
          Description of your role and achievements. Add your responsibilities, key projects, and impact here.
        </p>
      </div>
    </section>
  </div>

  <ContactSection />

  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>

