---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Link from "../../components/Link.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects", ({ data }) => !data.draft);
---
<BaseLayout title="Work | Personal Site" description="Selected work and projects">
  <Fragment slot="nav"><Nav /></Fragment>
  <section class="space-y-6">
    <h1 class="text-3xl font-semibold">Work</h1>
    {projects.length === 0 ? (
      <p>No projects yet. Add some in <code>src/content/projects</code>.</p>
    ) : (
      <ul class="space-y-4">
        {projects.map((p) => (
          <li class="border rounded p-4">
            <Link href={`/work/${p.slug}`} class="text-lg font-medium">
              {p.data.title}
            </Link>
            {p.data.summary && <p class="text-sm text-gray-600 mt-1">{p.data.summary}</p>}
          </li>
        ))}
      </ul>
    )}
  </section>
  <Fragment slot="footer"><Footer /></Fragment>
</BaseLayout>

