---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import Link from "../components/Link.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactSection from "../components/ContactSection.astro";
---
<BaseLayout title="Home | Personal Site" description="Welcome to my personal site">
  <Fragment slot="nav">
    <Nav />
  </Fragment>
  <!-- Main Hero (Full Height) -->
  <section class="border-b-4 flex flex-col justify-end h-[calc(100vh-176px)] pb-10 gap-1">
    <h1 class="text-9xl uppercase leading-tight text-gray-800">
      Hey there, I'm <span class="highlight-hero">David</span>.<br />
      A <span class="highlight-hero delay-1">software engineer</span>,<br />
      that <span class="highlight-hero delay-2">loves good work</span>.
    </h1>
  </section>


  <!-- About me section -->
  <div class="mt-20 max-w-7xl mx-auto">
    <h2 class="text-lg text-gray-600 uppercase tracking-wider mb-8">About Me</h2>
    <section class="my-12 grid md:grid-cols-2 gap-8 md:gap-12 items-start">
    <div>
      <h2 class="text-3xl md:text-5xl lg:text-5xl leading-tight  text-gray-800">
        Experienced Software Engineer with passion for innovation and startups
      </h2>
      <p class="mt-8 text-gray-700 text-lg">
        I'm David, an experienced software engineer with expertise in creating SaaS products, websites, and mobile applications for businesses.
      </p>
      <p class="mt-4 text-gray-700 text-lg">
        I work closely with my colleagues to deliver exceptional results that exceed expectations. If you’re looking for a dedicated software engineer to help bring your ideas to life, don’t hesitate to send me an email!
      </p>
      <div class="mt-8">
        <Link href="mailto:david@daviddelatorre.com" variant="inline" class="text-xl">
          Let's Work Together →
        </Link>
      </div>
    </div>
    <div class="relative">
      <img
        src="/img/yop.jpg"
        alt="David working at his laptop"
        class="w-full h-auto object-cover shadow-xl/30 border border-gray-300 rounded-lg"
      />
    </div>
  </section>
  </div>
