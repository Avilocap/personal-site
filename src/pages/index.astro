---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Under Construction | David" description="Building a new website">
  <Fragment slot="header">
    <!-- No header for construction page -->
  </Fragment>
  <!-- Under Construction Banner -->
  <div class="flex items-center justify-center min-h-[calc(100vh-200px)]">
    <div class="max-w-4xl mx-auto text-center px-4">
      <!-- Main Message -->
      <div class="border-4 border-black p-8 md:p-16 bg-white/80">
        <div class="mb-8">
          <svg class="w-20 h-20 mx-auto text-gray-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
          </svg>
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-6 leading-tight">
          I'm building a new website
        </h1>
        
        <p class="text-xl md:text-2xl text-gray-600 mb-8 leading-relaxed">
          that better represents me
        </p>
        
        <div class="inline-block">
          <p class="text-lg md:text-xl text-gray-800 font-medium">
            <span class="highlight-hero">Come back soon</span>
          </p>
        </div>

        <!-- Optional: Contact info -->
        <div class="mt-12 pt-8 border-t-2 border-gray-200">
          <p class="text-gray-600 mb-4">In the meantime, you can reach me at:</p>
          <a 
            href="mailto:david@daviddelatorre.me" 
            class="inline-block text-lg text-gray-800 hover:text-gray-900 font-medium transition-colors"
          >
            david@daviddelatorre.me
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
