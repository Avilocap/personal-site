---
const links = [
  { href: '/', label: 'HOME' },
  { href: '/work', label: 'WORK' },
  { href: '/about', label: 'ABOUT ME' },
  { href: '/blog', label: 'BLOG' },
  { href: '/contact', label: 'CONTACT' },
];

// Get current path to highlight active link
const currentPath = Astro.url.pathname;
---
<nav class="flex items-center justify-between w-full">
  <!-- Logo/Name with ultra-thin typography -->
  <a 
    href="/" 
    class="text-xl font-bold tracking text-gray-900 hover:text-gray-600 transition-colors duration-300"
  >
    DAVID DE LA TORRE
  </a>
  
  <!-- Navigation links -->
  <ul class="flex items-center gap-8">
    {links.map((link) => {
      const isActive = currentPath === link.href || 
                      (link.href !== '/' && currentPath.startsWith(link.href));
      return (
        <li class="relative">
          <a 
            href={link.href}
            class={`
              text-md font-bold tracking-[0.15em] transition-all duration-300
              ${isActive 
                ? 'text-gray-900' 
                : 'text-gray-600 hover:text-gray-900'
              }
            `}
          >
            {link.label}
            {/* Ultra-thin underline for active state */}
            {isActive && (
              <span class="absolute -bottom-2 left-0 right-0 h-[0.5px] bg-gray-900"></span>
            )}
          </a>
        </li>
      );
    })}
  </ul>
</nav>

