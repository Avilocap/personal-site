---
import Link from './Link.astro';

const links = [
  { href: '/', label: 'HOME' },
  // { href: '/work', label: 'WORK' },
  { href: '/about', label: 'ABOUT ME' },
  { href: '/blog', label: 'BLOG' },
  { href: '/contact', label: 'CONTACT' },
];

// Get current path to highlight active link
const currentPath = Astro.url.pathname;
---
<nav class="flex w-full flex-col items-start gap-4 md:flex-row md:items-center md:justify-between">
  <!-- Logo/Name with ultra-thin typography -->
  <Link
    href="/"
    class="text-xl font-bold tracking text-gray-900 hover:text-gray-600"
  >
    DAVID DE LA TORRE
  </Link>
  
  <!-- Navigation links -->
  <ul class="flex w-full flex-wrap items-center gap-x-5 gap-y-3 md:w-auto md:gap-8">
    {links.map((link) => {
      const isActive = currentPath === link.href ||
                      (link.href !== '/' && currentPath.startsWith(link.href));
      return (
        <li class="relative">
          <Link
            href={link.href}
            variant="nav"
            class={`
              whitespace-nowrap text-sm tracking-[0.1em] md:text-base md:tracking-[0.15em]
              ${isActive
                ? 'text-gray-900 [&>span:first-child>span:first-child]:scale-x-110'
                : 'text-gray-600'
              }
            `}
          >
            {link.label}
          </Link>
        </li>
      );
    })}
  </ul>
</nav>
