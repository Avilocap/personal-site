---
export interface Props {
  href: string;
  class?: string;
  variant?: 'default' | 'nav' | 'inline';
  external?: boolean;
}

const { 
  href, 
  class: className = '', 
  variant = 'default',
  external = false 
} = Astro.props;

// Determine if link is external
const isExternal = external || href.startsWith('http');

// Base classes for the link
// Add `group` so we can animate inner highlight on hover regardless of outer display
const baseClasses = 'relative inline-block transition-all duration-300 group';

// Variant-specific classes (text colors, typography only)
const variantClasses = {
  default: 'text-gray-700 hover:text-gray-900',
  nav: 'text-md font-bold tracking-[0.15em] text-gray-600 hover:text-gray-900',
  inline: 'text-current hover:text-gray-900'
};

// Highlighter height based on variant
const highlighterHeight = {
  default: 'h-2',
  nav: 'h-2',
  inline: 'h-1.5'
};

const linkClasses = `${baseClasses} ${variantClasses[variant]} ${className}`;
---

<a 
  href={href}
  class={linkClasses}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener noreferrer' : undefined}
>
  {/* Wrap text in a relative inline-block container so the highlighter width matches the text */}
  <span class="relative inline-block">
    {/* Yellow highlighter effect bound to text width */}
    <span class={`
      absolute left-0 right-0 bottom-0 -z-10
      bg-yellow-300/70 
      ${highlighterHeight[variant]}
      transition-all duration-300 ease-out
      scale-x-0 origin-left
      group-hover:scale-x-110
    `}></span>

    <span class="relative z-10">
      <slot />
    </span>
  </span>
</a>