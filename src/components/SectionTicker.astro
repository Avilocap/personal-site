---
export interface Props {
  label: string;
  /** Optional: override speed in seconds for one loop */
  durationSec?: number;
}

const { label, durationSec = 30 } = Astro.props as Props;

// Base sequence repeated to ensure overflow
const base = Array.from({ length: 10 }).map(() => label);
// Duplicate sequence so the first half equals the second half and the
// -50% translate loop is seamless
const items = [...base, ...base];
---
<div class="border-y-4 overflow-hidden select-none">
  <div
    class="ticker-track flex items-center gap-40 py-3 font-bold text-gray-800 text-2xl md:text-3xl uppercase"
    style={`--ticker-duration:${durationSec}s`}
    aria-hidden="true"
  >
    {items.map((text) => (
      <span class="shrink-0">{text}</span>
    ))}
  </div>
</div>

